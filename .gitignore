# --- Bonsai-Eval data policy: regenerate-only ---
# Raw transcripts may include PII (paths, prompt content) — never commit.
data/raw/
# Derived parquet stores are reproducible from scripts — keep scripts, not data.
data/*.parquet
data/joined/
charts/
# Synthetic fixture parquets — regenerated by `tests/conftest.py` on test run.
tests/fixtures/*.parquet

