# Bonsai-Eval — environment template. Copy to .env and fill in.
# .env is gitignored; never commit your real key.

# Anthropic API key — required for `make eval` and any solver that hits the API.
# Personal billing per Plan 38 §"Locked Decisions". Max-plan OAuth (claude CLI)
# does NOT cover SDK-direct calls.
ANTHROPIC_API_KEY=

# Optional: override Claude Code project transcript root (default: ~/.claude/projects).
# CLAUDE_PROJECTS_ROOT=

# Optional: path to the Bonsai repo for telemetry collect_git.py
# (default: assumes sibling checkout at ../Bonsai).
# BONSAI_REPO_PATH=

# Optional: cap days of transcripts to ingest (default: 90).
# TRANSCRIPT_MAX_AGE_DAYS=90
